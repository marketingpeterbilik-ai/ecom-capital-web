---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  chrome?: boolean;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Ecom Capital — Performance & Data Studio',
  description = 'Performance & data štúdio. Spravujeme PPC, staviame spoľahlivé meranie a dátovú infraštruktúru — GA4, server-side tracking, BigQuery a reporting v Looker Studio.',
  lang = 'sk',
  chrome = true,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
const siteUrl = new URL('/', Astro.site).href;

// Základná entita webu — pomáha AI vyhľadávačom aj klasickému SEO rozpoznať značku.
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Ecom Capital',
  legalName: 'Ecom Capital s.r.o.',
  url: siteUrl,
  logo: new URL('/og.png', Astro.site).href,
  description:
    'Performance & data štúdio — správa PPC kampaní, meranie a dátová infraštruktúra pre e-shopy.',
  areaServed: 'SK',
};
const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Ecom Capital',
  url: siteUrl,
  inLanguage: 'sk-SK',
};
const graph = [orgLd, siteLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="sk_SK" />
  <meta property="og:site_name" content="Ecom Capital" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImage} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(graph)} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>document.documentElement.classList.add('js');</script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  {chrome ? (
    <>
      <a href="#main" class="skip-link">Preskočiť na obsah</a>
      <Header />
      <main id="main">
        <slot />
      </main>
      <Footer />
    </>
  ) : (
    <slot />
  )}

  <script>
    // Reveal-on-scroll (+ batch stagger: susedné prvky odhalené naraz nabiehajú postupne)
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els = Array.from(document.querySelectorAll('.reveal'));
    if (!('IntersectionObserver' in window) || reduce) {
      els.forEach((el) => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          let i = 0;
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            const el = e.target as HTMLElement;
            el.style.transitionDelay = Math.min(i * 70, 420) + 'ms';
            const clear = () => (el.style.transitionDelay = '');
            el.addEventListener('transitionend', clear, { once: true });
            setTimeout(clear, 1400);
            el.classList.add('in');
            io.unobserve(el);
            i++;
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
      );
      els.forEach((el) => io.observe(el));
    }

    // Count-up čísel (proof strip, mini štatistiky) — text ostáva bez JS/pri reduced motion
    const nums = Array.from(document.querySelectorAll<HTMLElement>('.proof-item b, .mini-stat .v'));
    if (!reduce && 'IntersectionObserver' in window && nums.length) {
      const animate = (el: HTMLElement) => {
        const m = (el.textContent || '').match(/^([^0-9]*)(\d+(?:[.,]\d+)?)(.*)$/);
        if (!m) return;
        const target = parseFloat(m[2].replace(',', '.'));
        if (!isFinite(target) || target <= 0) return;
        const [, prefix, , suffix] = m;
        const dur = 900;
        const t0 = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - t0) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = prefix + Math.round(target * eased) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      const nio = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            animate(e.target as HTMLElement);
            nio.unobserve(e.target);
          });
        },
        { threshold: 0.5 }
      );
      nums.forEach((el) => nio.observe(el));
    }
  </script>
</body>
</html>
