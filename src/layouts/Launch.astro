---
import Base from './Base.astro';
import '../styles/launch.css';
import type { CountryLaunch } from '../data/launches';

interface Props {
  launch: CountryLaunch;
  title: string;
  description: string;
}

const { launch, title, description } = Astro.props;
---

<Base title={title} description={description} lang="en" chrome={false}>
  <nav class="lp-nav">
    <div class="wrap lp-nav-inner">
      <a class="lp-logo" href="/"><b class="lp-wordmark">ecom capital<i class="dot"></i></b></a>
      <div class="lp-nav-right">
        <a class="lp-nav-link" href="#calc">Calculator</a>
        <a class="lp-nav-link" href="#get">What you get</a>
        <a class="lp-nav-link" href="#why">Why me</a>
        <a class="lp-nav-link" href="#book">Contact</a>
        <a class="lp-nav-cta" href="#book">Book the 15-min check</a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="lp-foot">
    <div class="wrap lp-foot-inner">
      <span class="lp-foot-logo"
        ><b class="lp-wordmark lp-wordmark--inverse">ecom capital<i class="dot"></i></b>
        Google Shopping launch specialist · {launch.countryName}</span
      >
      <span class="lp-foot-links">
        <a href="/">ecomcapital.sk →</a>
        <a href="mailto:peter@ecomcapital.sk">peter@ecomcapital.sk</a>
      </span>
    </div>
  </footer>

  <div class="lp-sticky">
    <span class="lp-sticky-note"
      >{launch.googleDomain.toUpperCase()} SHOPPING · OPENS {launch.launchWindow.toUpperCase()} · SETUP TAKES 10 DAYS</span
    >
    <a class="lp-sticky-cta" href="#book">Book the free 15-min check →</a>
  </div>
</Base>
