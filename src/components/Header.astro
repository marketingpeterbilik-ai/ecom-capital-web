---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const links = [
  { href: '/', label: 'Domov' },
  { href: '/sluzby', label: 'Služby' },
  { href: '/data', label: 'Dáta & BigQuery' },
  { href: '/kalkulacka', label: 'Kalkulačka' },
  { href: '/proces', label: 'Proces' },
  { href: '/o-mne', label: 'O mne' },
  { href: '/blog', label: 'Blog' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<header class="site">
  <div class="wrap nav">
    <a href="/" class="mark"><b>ecom capital<i class="dot"></i></b><small>Performance · Analytics · Data</small></a>
    <nav class="nav-links" id="navlinks">
      {links.map((l) => (
        <a href={l.href} class={isActive(l.href) ? 'active' : ''} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </nav>
    <div class="nav-cta"><a href="/kalkulacka" class="btn btn--primary">Spočítať cenu</a></div>
    <button class="burger" id="burger" aria-label="Menu" aria-controls="navlinks" aria-expanded="false"><span></span><span></span><span></span></button>
  </div>
</header>

<script>
  // Mobile menu toggle
  const burger = document.getElementById('burger');
  const nl = document.getElementById('navlinks');

  function setMenu(open: boolean) {
    nl?.classList.toggle('open', open);
    burger?.classList.toggle('open', open);
    burger?.setAttribute('aria-expanded', String(open));
  }

  burger?.addEventListener('click', () => {
    setMenu(!nl?.classList.contains('open'));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && nl?.classList.contains('open')) {
      setMenu(false);
      burger?.focus();
    }
  });
</script>
