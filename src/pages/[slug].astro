---
import Launch from '../layouts/Launch.astro';
import CalEmbed from '../components/CalEmbed.astro';
import { launches, type CountryLaunch } from '../data/launches';

export function getStaticPaths() {
  return launches.map((launch) => ({
    params: { slug: launch.slug },
    props: { launch },
  }));
}

interface Props {
  launch: CountryLaunch;
}

const { launch } = Astro.props;
const { countryName, adjective, googleDomain, launchWindow } = launch;

const title = `${countryName} — Google Shopping Launch | Ecom Capital`;
const description = `Google Shopping launches in ${countryName} in ${launchWindow}. Be the first ${adjective} shop in the results — before CPCs triple. A specialist running Shopping across 10+ EU markets.`;
---

<Launch launch={launch} title={title} description={description}>
  <!-- HERO -->
  <header class="lp-hero">
    <div class="lp-hero-noise"></div>
    <div class="lp-hero-orb a"></div>
    <div class="lp-hero-orb b"></div>
    <div class="wrap lp-hero-inner">
      <span class="lp-chip reveal"><span class="lp-chip-dot"></span>NEW · Google Shopping arrives in {countryName} — <b>{launchWindow}</b></span>
      <h1 class="reveal">Shopping ads have never existed on {googleDomain}. <span class="hl">That changes in {launchWindow}.</span></h1>
      <p class="lp-sub reveal">
        Google is bringing Shopping ads — product photos with prices at the top of search results — to {countryName} for the first
        time. <strong>No {adjective} shop has them. No local agency has ever set them up.</strong> The shops that launch first acquire
        customers cheapest. This page exists to make sure that's you.
      </p>
      <div class="lp-cta-row reveal">
        <a class="btn btn--primary btn--lg" href="#book">Check my market position →</a>
        <a class="btn btn--ghost btn--lg" href="#calc" style="border-color:rgba(255,255,255,.4); color:#fff">Calculate my upside</a>
        <span class="lp-cta-note">48H ANSWER · YOU TALK DIRECTLY TO ME</span>
      </div>
    </div>
  </header>

  <!-- SERP MOCK -->
  <section class="lp-serp-zone">
    <div class="wrap">
      <div class="lp-serp reveal">
        <div class="lp-serp-bar">
          <div class="lp-serp-search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8A8A96" stroke-width="2.2"
              ><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg
            >
            espresso machine — buy online
          </div>
          <span class="lp-serp-label">{googleDomain} · Shopping results · day one</span>
        </div>
        <div class="lp-cards">
          <div class="lp-pcard"><div class="lp-img"></div><div class="lp-t">Espresso Machine 15 Bar Steel</div><div class="lp-price">€249.00</div><div class="lp-shop">german-shop.de</div></div>
          <div class="lp-pcard"><div class="lp-img"></div><div class="lp-t">Coffee Maker Pro 1350W</div><div class="lp-price">€189.00</div><div class="lp-shop">eu-megastore.com</div></div>
          <div class="lp-pcard you"><span class="lp-badge">EMPTY SLOT</span><span class="lp-yt">Your shop belongs here.</span><span class="lp-ys">Before a foreign seller takes it.</span></div>
          <div class="lp-pcard"><div class="lp-img"></div><div class="lp-t">Barista Espresso Set + Grinder</div><div class="lp-price">€312.00</div><div class="lp-shop">global-deals.eu</div></div>
          <div class="lp-pcard"><div class="lp-img"></div><div class="lp-t">Espresso Maker Compact Black</div><div class="lp-price">€159.00</div><div class="lp-shop">import-store.com</div></div>
        </div>
        <p class="lp-serp-foot">
          Day one, the first slots get taken by <strong>cross-border sellers from Germany and Poland</strong> — not local shops. With
          local delivery, language and trust, you beat them. <strong>But only if you're in the auction.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- NEW CHANNEL -->
  <section class="sec sec--ink">
    <div class="wrap">
      <span class="eyebrow reveal">A new channel — not an upgrade</span>
      <h2 class="display reveal" style="margin-top:16px; font-size:clamp(1.9rem,4.6vw,3rem)">This is a brand-new sales channel for {countryName}.</h2>
      <p class="lead reveal" style="margin-top:16px">
        Your current Google ads are <strong>Search ads — text only.</strong> Shopping ads show your product photo, price and shop name
        above every text result. Until now, Google didn't offer them in {countryName} — that's why you've never seen them on {googleDomain}.
      </p>
      <div class="lp-facts reveal">
        <div class="lp-fact"><span class="lp-f-num">01 / SALES</span><h3>More orders, same budget</h3><p>The customer sees your <b>photo and price before clicking.</b> Those who click already want the product — <b>same budget, more orders.</b></p></div>
        <div class="lp-fact"><span class="lp-f-num">02 / TIMING</span><h3>The window is short</h3><p>Day one, the {adjective} auction is <b>nearly empty — clicks cost cents.</b> Every shop that joins later pushes prices up. <b>The cheap period never returns.</b></p></div>
        <div class="lp-fact"><span class="lp-f-num">03 / EDGE</span><h3>Locals can't help you</h3><p>{adjective} agencies have <b>never set up a Merchant Center or feed</b> — the channel didn't exist here. Their trial and error is <b>paid for with your budget.</b></p></div>
      </div>
    </div>
  </section>

  <!-- WAIT -->
  <section class="sec" id="wait">
    <div class="wrap">
      <span class="eyebrow reveal" style="color:var(--coral)">Loss runs faster than profit</span>
      <h2 class="display reveal" style="margin-top:16px; font-size:clamp(1.9rem,4.6vw,3rem)">What happens if you wait?</h2>
      <p class="lead reveal" style="margin-top:16px">
        This is how every new Google market plays out. The product doesn't change. The customer doesn't change. <strong>Only the price
        you pay to reach them changes.</strong>
      </p>
      <div class="lp-wait-chart reveal">
        <div class="lp-wait-col">
          <div class="lp-wait-bar lp-wb-1">×1<span class="lp-bx">CPC</span></div>
          <div class="lp-wait-info"><span class="lp-when">Launch — you go first</span><h3>The auction is empty</h3><p>Almost nobody is bidding. You acquire customers at the cheapest price this market will ever offer.</p></div>
        </div>
        <div class="lp-wait-col">
          <div class="lp-wait-bar lp-wb-2">×1.5<span class="lp-bx">CPC</span></div>
          <div class="lp-wait-info"><span class="lp-when">~ Month 3 — the crowd arrives</span><h3>Competitors enter</h3><p>Local shops catch on. More bidders, higher prices — while early movers already have months of data working for them.</p></div>
        </div>
        <div class="lp-wait-col">
          <div class="lp-wait-bar lp-wb-3">×3<span class="lp-bx">CPC</span></div>
          <div class="lp-wait-info"><span class="lp-when">~ Month 6+ — saturation</span><h3>Triple the price</h3><p>Crowded auctions, established players, optimized feeds. Latecomers pay 3× more for the customer they could have had on day one.</p></div>
        </div>
      </div>
      <p class="lp-wait-punch reveal">Waiting isn't free. <em>It's the difference between ×1 and ×3 — forever.</em></p>

      <div class="lp-data-strip reveal">
        <div class="lp-data-head">— This isn't a sales pitch. It's measured data. —</div>
        <div class="lp-data-cards">
          <div class="lp-dcard"><div class="lp-dv">10–15% lower CPC</div><p>Across Europe, Shopping &amp; Performance Max clicks cost <b>10–15% less than text Search</b> — €0.36–0.41 vs €0.42–0.45 median CPC. In a newly opened market, the gap is initially wider.</p><div class="lp-src">Smarter eCommerce (smec) European retail benchmark, H1 2026 — €650M+ ad spend</div></div>
          <div class="lp-dcard"><div class="lp-dv">60%+ of retail clicks</div><p>Shopping isn't a minor add-on. In established markets, product formats capture <b>over 60% of all retail search clicks.</b> Text-only advertisers fight over the remaining 40%.</p><div class="lp-src">Search performance &amp; retail inventory share data, 2025/2026</div></div>
          <div class="lp-dcard"><div class="lp-dv">+12–13% conversions</div><p>Advertisers moving to feed-based Performance Max see <b>12–13% more conversions at equal or better ROAS.</b> Buyers see your photo and price before clicking — no more paying for unqualified traffic.</p><div class="lp-src">Google internal data, retail Performance Max case studies</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="sec sec--tint lp-calc" id="calc">
    <div class="wrap">
      <span class="eyebrow reveal">Your numbers, not ours</span>
      <h2 class="display reveal" style="margin-top:16px; font-size:clamp(1.9rem,4.6vw,3rem)">What does the window mean for your shop?</h2>
      <p class="lead reveal" style="margin-top:16px; margin-bottom:12px">
        Move the sliders. The math shows what launching first vs. waiting six months means <strong>in clicks, orders and revenue — for
        your budget.</strong>
      </p>
      <div class="calc reveal">
        <div class="calc-controls">
          <div class="cgroup">
            <div class="clabel">Your inputs</div>
            <div class="chint">Rough numbers are fine — this is about the size of the gap, not the decimals.</div>
          </div>
          <div class="cgroup">
            <div class="slider-row"><span class="clabel">Monthly Shopping budget</span><span class="slider-val" id="budgetVal">€1,500</span></div>
            <input type="range" id="budget" min="300" max="10000" step="100" value="1500" />
            <div class="slider-ends"><span>€300</span><span>€10,000</span></div>
          </div>
          <div class="cgroup">
            <div class="slider-row"><span class="clabel">Average order value</span><span class="slider-val" id="aovVal">€60</span></div>
            <input type="range" id="aov" min="20" max="500" step="10" value="60" />
            <div class="slider-ends"><span>€20</span><span>€500</span></div>
          </div>
        </div>
        <div class="calc-result">
          <div class="lp-res"><span class="lp-r-label">Launching now · CPC ≈ €0.12</span><div class="lp-r-val up" id="clicksNow">—</div><div class="lp-r-sub">≈ <span id="ordersNow">—</span> orders / mo · ≈ <span id="revNow">—</span> revenue / mo</div></div>
          <div class="lp-res"><span class="lp-r-label">Entering at month 6+ · CPC ≈ €0.36</span><div class="lp-r-val down" id="clicksLate">—</div><div class="lp-r-sub">≈ <span id="ordersLate">—</span> orders / mo · ≈ <span id="revLate">—</span> revenue / mo</div></div>
          <div class="lp-res"><span class="lp-r-label">The cost of waiting — per year</span><div class="lp-r-val down" id="lostRev">—</div><div class="lp-r-sub">Same budget. Same customers. Different timing.</div></div>
        </div>
      </div>
      <p class="lp-calc-note reveal">
        Illustrative model — launch CPC €0.12 vs saturated CPC €0.36 (3×), conversion rate 1.5%. Real figures depend on your niche,
        margin and feed quality; that's precisely what the free market check establishes for you.
      </p>
    </div>
  </section>

  <!-- VALUE STACK -->
  <section class="sec" id="what">
    <div class="wrap">
      <span class="eyebrow reveal">Measured in money, not jargon</span>
      <h2 class="display reveal" style="margin-top:16px; font-size:clamp(1.9rem,4.6vw,3rem)">What you get</h2>
      <p class="lead reveal" style="margin-top:16px">You don't need to understand feeds or Merchant Center. That's my job. Here's what each piece means <strong>for your revenue.</strong></p>
      <div class="lp-stack reveal">
        <div class="lp-stack-item"><span class="lp-idx">01</span><h3>Your products appear on {googleDomain} — period.</h3><p>Without an approved Merchant Center, Google won't show your products. <b>I handle the entire approval</b> — the step where DIY attempts get stuck for weeks.</p><p class="lp-how"><b>HOW —</b> Merchant Center setup, verification &amp; policy compliance</p></div>
        <div class="lp-stack-item"><span class="lp-idx">02</span><h3>You reach people ready to buy — not browse.</h3><p>Done right, your ads appear for searches with a credit card behind them. <b>More orders from the same budget.</b></p><p class="lp-how"><b>HOW —</b> product feed built &amp; optimized for buying-intent searches</p></div>
        <div class="lp-stack-item"><span class="lp-idx">03</span><h3>Profitable sooner — no paid trial &amp; error.</h3><p>A badly built account burns budget for three months "learning." <b>Mine is built on what already works in 10+ markets.</b></p><p class="lp-how"><b>HOW —</b> campaign architecture proven across EU Shopping launches</p></div>
        <div class="lp-stack-item"><span class="lp-idx">04</span><h3>You'll know exactly where the open space is.</h3><p>I check which competitors are preparing Shopping and which are asleep. <b>Where you can win cheaply — in numbers, not feelings.</b></p><p class="lp-how"><b>HOW —</b> competitor visibility report for your exact niche</p></div>
        <div class="lp-stack-item"><span class="lp-idx">05</span><h3>Not one euro spent blind.</h3><p>Before launch I verify your conversion tracking works. <b>You'll know exactly how much every euro brought back.</b></p><p class="lp-how"><b>HOW —</b> GA4 &amp; conversion tracking audit before any spend</p></div>
        <div class="lp-stack-item"><span class="lp-idx">06</span><h3>Someone watches your money every day.</h3><p>Waste cut weekly, winners scaled, feed problems fixed before they cost sales. <b>Plus a monthly report in plain language.</b></p><p class="lp-how"><b>HOW —</b> ongoing optimization, feed monitoring &amp; honest reporting</p></div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="sec sec--tint" id="how">
    <div class="wrap">
      <span class="eyebrow reveal">A fixed, proven sequence</span>
      <h2 class="display reveal" style="margin-top:16px; font-size:clamp(1.9rem,4.6vw,3rem)">Live in 10 working days.</h2>
      <p class="lead reveal" style="margin-top:16px">You'll know exactly where we are at every step — <strong>and what it's bringing you.</strong></p>
      <div class="lp-proc reveal">
        <div class="lp-proc-row"><div class="lp-proc-when">DAY 0</div><div class="lp-proc-body"><h3>Free market check</h3><p>15 minutes. {countryName}'s rollout status, your competitors' readiness, whether your shop qualifies. If it's not a fit, I'll tell you straight — and you've lost nothing.</p></div></div>
        <div class="lp-proc-row"><div class="lp-proc-when">DAYS 1–3</div><div class="lp-proc-body"><h3>Foundation</h3><p>Merchant Center approved, product catalogue turned into a compliant, optimized feed. You send access — I do the rest. Your part takes 20 minutes.</p></div></div>
        <div class="lp-proc-row"><div class="lp-proc-when">DAYS 4–7</div><div class="lp-proc-body"><h3>Build &amp; verify</h3><p>Campaigns built, budgets set, conversion tracking verified — so from the first click, we measure real revenue, not vanity metrics.</p></div></div>
        <div class="lp-proc-row"><div class="lp-proc-when">DAYS 8–10</div><div class="lp-proc-body"><h3>Launch</h3><p>Your products go live in Shopping results on {googleDomain} — in all likelihood before any of your local competitors.</p></div></div>
        <div class="lp-proc-row"><div class="lp-proc-when">DAYS 11–40</div><div class="lp-proc-body"><h3>Optimization sprint</h3><p>The first 30 days decide the next 12 months. Daily monitoring, cutting waste, scaling winners — and a clear report on what your money did.</p></div></div>
      </div>
    </div>
  </section>

  <!-- EXPERT -->
  <section class="sec sec--ink">
    <div class="wrap">
      <div class="lp-expert">
        <div class="lp-expert-copy">
          <span class="eyebrow reveal">Why me</span>
          <h2 class="display reveal" style="margin-top:16px; margin-bottom:26px; font-size:clamp(1.9rem,4.2vw,2.7rem)">The setup local agencies will spend the next year learning is my daily routine.</h2>
          <p class="reveal"><b>Today, I manage live Shopping campaigns across 10+ European markets</b> — feeds, Merchant Centers, campaign structures — in markets where this channel has existed for years.</p>
          <p class="reveal">When Shopping opens in {countryName}, I'm not learning anything new. <b>I'm running a proven playbook on a fresh map where the auction is still empty.</b></p>
          <p class="reveal">No agency, no juniors, no account managers. <b>You work directly with the person whose hands are in the account.</b></p>
        </div>
        <div class="lp-nums reveal">
          <div class="lp-num"><div class="lp-v">10+</div><div class="lp-l">EU markets with live Shopping campaigns today</div></div>
          <div class="lp-num"><div class="lp-v">€5M+</div><div class="lp-l">ad spend managed across Google &amp; Meta</div></div>
          <div class="lp-num"><div class="lp-v">250K+</div><div class="lp-l">products managed across feeds &amp; platforms</div></div>
          <div class="lp-num"><div class="lp-v">15+</div><div class="lp-l">CEE price-comparison &amp; marketplace platforms</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- GUARANTEE -->
  <section class="sec">
    <div class="wrap">
      <div class="lp-guarantee reveal">
        <div class="lp-shield">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#9FE870" stroke-width="1.8"
            ><path d="M12 2 4 5.5V11c0 5 3.4 9.3 8 10.5 4.6-1.2 8-5.5 8-10.5V5.5L12 2Z"></path><path d="m8.5 11.5 2.5 2.5 4.5-4.5"></path></svg
          >
        </div>
        <div class="lp-g-body">
          <h3>Live in 10 working days — or the setup is free.</h3>
          <p>
            If your campaigns aren't live within 10 working days of getting access (and your shop meets Google's policies), <strong
              >you don't pay the setup fee.</strong
            > No long-term contracts — month to month, because results should be the reason you stay, not a signature.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BOOKING -->
  <section class="sec sec--tint" id="book">
    <div class="wrap">
      <div class="lp-form-zone">
        <div class="reveal">
          <span class="eyebrow">Free market check</span>
          <h2 class="display" style="margin-top:16px; font-size:clamp(1.9rem,4.6vw,3rem)">Find out where {countryName} stands — and where you stand in it.</h2>
          <p class="lead" style="margin-top:16px">
            Book a free 15-minute call. We'll cover {countryName}'s rollout status, whether your shop qualifies, and which competitors
            are already moving. <strong>Free, no obligation.</strong>
          </p>
          <ul class="lp-check-list">
            <li><span class="lp-ic"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6 9 17l-5-5"></path></svg></span><span><strong>Market status</strong> — when Shopping opens for your niche in {countryName}</span></li>
            <li><span class="lp-ic"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6 9 17l-5-5"></path></svg></span><span><strong>Competitor check</strong> — who in your space is already preparing, who's asleep</span></li>
            <li><span class="lp-ic"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6 9 17l-5-5"></path></svg></span><span><strong>Honest verdict</strong> — if Shopping isn't right for your shop yet, I'll tell you straight</span></li>
          </ul>
        </div>
        <div class="reveal">
          <CalEmbed noscriptText="To book a slot, enable JavaScript, or write directly to" />
        </div>
      </div>
    </div>
  </section>
</Launch>

<script>
  (function () {
    const CPC_NOW = 0.12,
      CPC_LATE = 0.36,
      CVR = 0.015;
    const budget = document.getElementById('budget') as HTMLInputElement | null;
    const aov = document.getElementById('aov') as HTMLInputElement | null;
    const fmtN = (n: number) => n.toLocaleString('en-US');
    const fmtE = (n: number) => '€' + Math.round(n).toLocaleString('en-US');

    function update() {
      if (!budget || !aov) return;
      const b = +budget.value,
        a = +aov.value;
      document.getElementById('budgetVal')!.textContent = fmtE(b);
      document.getElementById('aovVal')!.textContent = fmtE(a);
      const cNow = Math.round(b / CPC_NOW),
        cLate = Math.round(b / CPC_LATE);
      const oNow = cNow * CVR,
        oLate = cLate * CVR,
        rNow = oNow * a,
        rLate = oLate * a;
      document.getElementById('clicksNow')!.textContent = fmtN(cNow);
      document.getElementById('clicksLate')!.textContent = fmtN(cLate);
      document.getElementById('ordersNow')!.textContent = fmtN(Math.round(oNow));
      document.getElementById('ordersLate')!.textContent = fmtN(Math.round(oLate));
      document.getElementById('revNow')!.textContent = fmtE(rNow);
      document.getElementById('revLate')!.textContent = fmtE(rLate);
      document.getElementById('lostRev')!.textContent = fmtE((rNow - rLate) * 12);
    }
    budget?.addEventListener('input', update);
    aov?.addEventListener('input', update);
    update();
  })();
</script>
