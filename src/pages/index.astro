---
import Base from '../layouts/Base.astro';
import Booking from '../components/Booking.astro';
import StickyCta from '../components/StickyCta.astro';
---

<Base
  title="Ecom Capital — Správa PPC postavená na spoľahlivom meraní | Google & Meta Ads"
  description="Kampane v Google a Meta Ads a meranie, na ktorom stoja — GA4, server-side tracking, BigQuery. Reklama aj dáta pod jednou strechou."
>
  <header class="hero--ink">
    <div class="hero-orb"></div>
    <div class="wrap hero-inner">
      <span class="chip--live reveal"><span class="chip-dot"></span><b>Meranie v cene správy</b> · bez viazanosti</span>
      <h1 class="reveal">Správa PPC postavená na <span class="hl">spoľahlivom meraní</span>.</h1>
      <p class="hero-sub reveal">
        Kampane v Google a Meta Ads a meranie, na ktorom stoja — GA4, server-side tracking, BigQuery.
        Reklama aj dáta <strong>pod jednou strechou.</strong>
      </p>
      <div class="cta-row reveal">
        <a class="btn btn--primary btn--lg" href="#book">Rezervovať konzultáciu <span class="arrow-i">→</span></a>
        <span class="cta-note">NEZÁVÄZNE · ODPOVEĎ DO 48 HODÍN</span>
      </div>
      <div class="cta-row reveal" style="margin-top:18px">
        <a href="/kalkulacka" class="hero-textlink">Alebo si najprv spočítajte orientačnú cenu →</a>
      </div>
      <div class="proof reveal stagger">
        <div class="proof-item"><b>10+</b><div>EU trhov so živými kampaňami</div></div>
        <div class="proof-item"><b>€5M+</b><div>spravovaného spendu v Google &amp; Meta</div></div>
        <div class="proof-item"><b>50+</b><div>úspešných spoluprác</div></div>
        <div class="proof-item"><b>10 dní</b><div>od prístupov po spustenie kampaní</div></div>
      </div>
    </div>
  </header>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Ako to funguje</span>
        <h2 class="display">Od reklamy po rozhodnutie — jeden systém.</h2>
        <p class="lead">Reklama, meranie aj dáta sedia v jednom systéme a navzájom spolupracujú — namiesto skladania z viacerých dodávateľov.</p>
      </div>
      <div class="pipe-shell reveal">
        <div class="pipe-cap">Dátový tok — od reklamy po rozhodnutie</div>
        <div class="pipeline reveal stagger">
          <div class="node"><div class="idx">01 ZBER</div><div class="nm">Reklamy &amp; kanály</div><div class="sb">Google, Meta, GA4, feedy, CRM</div></div>
          <div class="arrow"><svg width="22" height="14" viewBox="0 0 22 14" fill="none"><path d="M0 7h19M14 1l6 6-6 6" stroke="currentColor" stroke-width="1.6"/></svg></div>
          <div class="node"><div class="idx">02 MERANIE</div><div class="nm">Tracking</div><div class="sb">GA4 + server-side, CAPI, consent</div></div>
          <div class="arrow"><svg width="22" height="14" viewBox="0 0 22 14" fill="none"><path d="M0 7h19M14 1l6 6-6 6" stroke="currentColor" stroke-width="1.6"/></svg></div>
          <div class="node hot"><div class="idx">03 SKLAD <span class="dot"></span></div><div class="nm">BigQuery</div><div class="sb">Jeden zdroj pravdy pre všetky dáta</div></div>
          <div class="arrow"><svg width="22" height="14" viewBox="0 0 22 14" fill="none"><path d="M0 7h19M14 1l6 6-6 6" stroke="currentColor" stroke-width="1.6"/></svg></div>
          <div class="node"><div class="idx">04 ROZHODNUTIE</div><div class="nm">Reporting</div><div class="sb">Looker Studio dashboardy</div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="sec sec--tint">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Služby</span>
        <h2 class="display">Od kampaní po dátový sklad.</h2>
        <p class="lead">Každá služba má vlastnú stránku s detailom. Fungujú samostatne aj ako celok.</p>
      </div>
      <div class="grid grid-3">
        <div class="card reveal">
          <div class="ico"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M12 1v4M12 19v4M1 12h4M19 12h4" stroke="currentColor" stroke-width="1.6"/></svg></div>
          <h3>Správa PPC kampaní</h3>
          <p>Google a Meta Ads vrátane produktových feedov. Optimalizácia podľa zisku a marže, nie podľa klikov.</p>
          <a href="/sluzby/ppc" class="more">Detail služby →</a>
        </div>
        <div class="card reveal">
          <div class="ico"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 12a9 9 0 0 1 9-9M6 12a6 6 0 0 1 6-6M9 12a3 3 0 0 1 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="12" cy="12" r="1.6" fill="currentColor"/></svg></div>
          <h3>Meranie &amp; tracking</h3>
          <p>GA4, server-side tracking, Meta CAPI. Meranie, ktoré obstojí aj v cookieless prostredí.</p>
          <a href="/sluzby/meranie" class="more">Detail služby →</a>
        </div>
        <div class="card reveal">
          <div class="ico"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="5.5" rx="7" ry="2.8" stroke="currentColor" stroke-width="1.6"/><path d="M5 5.5v13c0 1.5 3.1 2.8 7 2.8s7-1.3 7-2.8v-13M5 12c0 1.5 3.1 2.8 7 2.8s7-1.3 7-2.8" stroke="currentColor" stroke-width="1.6"/></svg></div>
          <h3>Dáta &amp; BigQuery</h3>
          <p>Marketingové dáta v jednom sklade — blended ROAS, CAC, LTV a automatizovaný reporting.</p>
          <a href="/data" class="more">Detail služby →</a>
        </div>
        <div class="card reveal">
          <div class="ico"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"/><path d="M16 16l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>
          <h3>Audit &amp; konzultácie</h3>
          <p>Nezávislé posúdenie účtov, merania a stratégie s akčným plánom podľa priorít.</p>
          <a href="/sluzby/audit" class="more">Detail služby →</a>
        </div>
        <div class="card reveal">
          <div class="ico"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg></div>
          <h3>Automatizácia</h3>
          <p>Skripty a alerty priebežne kontrolujú účty aj feedy a upozornia na problém včas.</p>
          <a href="/sluzby/automatizacia" class="more">Detail služby →</a>
        </div>
        <div class="card reveal">
          <div class="ico"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3l8 4v5c0 5-3.4 8-8 9-4.6-1-8-4-8-9V7l8-4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <h3>Cookie lišta &amp; Consent Mode v2</h3>
          <p>Súlad s GDPR a podmienkami Googlu vrátane testov a dokumentácie.</p>
          <a href="/cookie-consent" class="more">Detail služby →</a>
        </div>
      </div>
      <div class="reveal" style="margin-top:34px">
        <a href="/sluzby" class="btn btn--ghost">Prehľad všetkých služieb →</a>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="why reveal">
        <div>
          <span class="eyebrow">Prístup</span>
          <h2>Najprv meranie, potom rozpočty.</h2>
          <p>Spoľahlivé dáta sú podmienkou efektívneho míňania. Rozhodnutia vychádzajú <b>z čísel naprieč kanálmi,</b> nie z pohľadu jednej platformy.</p>
          <p>K spolupráci patrí transparentný prehľad o tom, čo sa na účtoch deje a aký to má dopad na tržby.</p>
          <a href="/proces" class="more">Ako prebieha spolupráca →</a>
        </div>
        <div class="mini-stats">
          <div class="mini-stat"><div class="v">10+</div><div class="l">EU trhov so živými kampaňami</div></div>
          <div class="mini-stat"><div class="v">€5M+</div><div class="l">spravovaného spendu</div></div>
          <div class="mini-stat"><div class="v">50+</div><div class="l">úspešných spoluprác</div></div>
          <div class="mini-stat"><div class="v">1</div><div class="l">kontakt na reklamy, tracking aj dáta</div></div>
        </div>
      </div>
    </div>
  </section>

  <Booking />
  <StickyCta />
</Base>
