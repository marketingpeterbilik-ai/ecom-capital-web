---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Stránka sa nenašla | Ecom Capital" description="Táto stránka neexistuje.">
  <section class="phero">
    <div class="wrap">
      <span class="eyebrow reveal">Chyba 404</span>
      <h1 class="display reveal">Stránka sa nenašla.</h1>
      <p class="lead reveal">Adresa neexistuje alebo sa presunula. K dispozícii je návrat na úvod alebo kontakt.</p>
      <div class="hero-cta reveal" style="margin-top:28px">
        <a href="/" class="btn btn--primary btn--lg">Späť na domov</a>
        <a href="/kontakt" class="btn btn--ghost btn--lg">Kontakt</a>
      </div>
    </div>
  </section>
</Base>
