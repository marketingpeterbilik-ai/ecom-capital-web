---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Stránka sa nenašla | Ecom Capital" description="Táto stránka neexistuje.">
  <header class="hero--ink hero--page" style="padding-bottom:96px">
    <div class="hero-orb"></div>
    <div class="wrap hero-inner">
      <span class="eyebrow reveal">Chyba 404</span>
      <h1 class="reveal" style="margin-top:18px">Stránka sa nenašla.</h1>
      <p class="hero-sub reveal">Adresa neexistuje alebo sa presunula. K dispozícii je návrat na úvod alebo kontakt.</p>
      <div class="cta-row reveal">
        <a href="/" class="btn btn--primary btn--lg">Späť na domov</a>
        <a href="/kontakt" class="hero-textlink">Kontakt →</a>
      </div>
    </div>
  </header>
</Base>
