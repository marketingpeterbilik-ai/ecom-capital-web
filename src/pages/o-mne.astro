---
import Base from '../layouts/Base.astro';
---

<Base
  title="O mne — Ecom Capital"
  description="Ecom Capital je jednočlenné performance & data štúdio. Robíš priamo s Petrom — žiadny account manager, žiadne stratené informácie medzi vrstvami ľudí."
>
  <section class="phero">
    <div class="wrap">
      <span class="eyebrow reveal">O mne / Štúdio</span>
      <h1 class="display reveal">Ecom Capital je jednočlenné štúdio. To je výhoda, nie obmedzenie.</h1>
      <p class="lead reveal">Som Peter — performance marketér s dátovým prístupom. Robíš priamo so mnou: žiadny account manager, žiadne stratené informácie medzi vrstvami ľudí.</p>
    </div>
  </section>

  <section class="sec" style="padding-top:16px">
    <div class="wrap">
      <div class="stats">
        <div class="stat reveal"><div class="n">14+</div><div class="c">európskych trhov pod správou</div></div>
        <div class="stat reveal"><div class="n">2</div><div class="c">platformy — Google + Meta, celý lievik</div></div>
        <div class="stat reveal"><div class="n">B2B + e-com</div><div class="c">od spotrebičov po poradenstvo</div></div>
        <div class="stat reveal"><div class="n">1</div><div class="c">človek za reklamy, tracking aj dáta</div></div>
      </div>
    </div>
  </section>

  <section class="sec sec--tint">
    <div class="wrap split">
      <div class="reveal">
        <span class="eyebrow">Prístup</span>
        <h2 class="display" style="margin-top:16px; font-size:clamp(1.8rem,4.2vw,2.6rem)">Systematicky, merateľne, na rovinu.</h2>
        <p class="lead" style="margin-top:18px">Mám vybudovaný vlastný systém na optimalizáciu a reporting naprieč klientmi. Vďaka tomu robím konzistentne a rýchlo — a ty dostávaš výsledok, nie výhovorky.</p>
      </div>
      <div class="reveal">
        <div class="feat"><div class="k">·</div><div><h4>Skills-first workflow</h4><p>Opakovateľné procesy a automatizácia namiesto ad-hoc roboty pri každom účte.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h4>Celý stack pod jednou strechou</h4><p>Merchant Center, feedy, CAPI, GA4, BigQuery — nemusíš to skladať z viacerých dodávateľov.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h4>Reporting, ktorému rozumieš</h4><p>Čo sa stalo, prečo a čo ďalej — v slovenčine, za pár minút, bez 40 grafov.</p></div></div>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head reveal"><span class="eyebrow">Sedíme si?</span><h2 class="display">Pre koho to je — a pre koho nie.</h2></div>
      <div class="who">
        <div class="who-card yes reveal">
          <h4>Sedíme si, ak…</h4>
          <ul>
            <li>máš e-shop alebo B2B a reklama je pre teba dôležitý kanál</li>
            <li>chceš rozumieť svojim dátam a rozhodovať sa podľa nich</li>
            <li>hľadáš dlhodobého parťáka, nie najlacnejšieho dodávateľa</li>
            <li>chceš jedného zodpovedného človeka, nie call centrum</li>
          </ul>
        </div>
        <div class="who-card no reveal">
          <h4>Asi si nesadneme, ak…</h4>
          <ul>
            <li>hľadáš zázrak cez noc bez investície do merania</li>
            <li>chceš len „najlacnejšie kliky" bez ohľadu na výsledok</li>
            <li>nechceš sa hýbať s trackingom ani dátami</li>
            <li>potrebuješ veľký brandový tím namiesto výkonu</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="sec sec--tint">
    <div class="wrap"><div class="ctaband reveal"><h2>Ak ti to dáva zmysel, ozvi sa.</h2><a href="/kontakt" class="btn btn--primary btn--lg">Napíš mi →</a></div></div>
  </section>
</Base>
