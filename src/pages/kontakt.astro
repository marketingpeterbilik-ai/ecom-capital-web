---
import Base from '../layouts/Base.astro';

// 👉 ZMEŇ na svoj Cal.com link (formát: "uzivatel/typ-eventu").
// Vytvoríš si ho zadarmo na https://cal.com — napr. "ecom-capital/konzultacia".
const CAL_LINK = 'ecom-capital/konzultacia';
---

<Base
  title="Kontakt — Ecom Capital"
  description="Rezervuj si nezáväzný hovor. Pozriem sa na tvoj účet a setup a dostaneš konkrétne odporúčania. Najhoršie, čo sa stane, je že sa dozvieš, kde ti tečú peniaze."
>
  <section class="phero">
    <div class="wrap">
      <span class="eyebrow reveal">Kontakt</span>
      <h1 class="display reveal">Nezáväzná konzultácia.</h1>
      <p class="lead reveal">Hovor, počas ktorého prejdeme stav účtu a meranie a výstupom sú konkrétne odporúčania. Bez záväzku a bez viazanosti.</p>
    </div>
  </section>

  <section class="sec" style="padding-top:20px">
    <div class="wrap contact-grid">
      <div class="reveal">
        <div class="ctitem"><div class="l">E-mail</div><div class="v"><a href="mailto:peter@ecomcapital.sk">peter@ecomcapital.sk</a></div></div>
        <div class="ctitem"><div class="l">Lokalita</div><div class="v">Bratislava, Slovensko</div></div>
        <div class="ctitem"><div class="l">Záber</div><div class="v">PPC · Analytika · Dáta &amp; BigQuery</div></div>
        <div class="ctitem"><div class="l">Spolupráca</div><div class="v">Jednorazové projekty aj dlhodobá správa</div></div>
        <p style="margin-top:24px; color:var(--ink-soft)">Termín konzultácie je možné rezervovať priamo v kalendári vpravo. Pre orientačnú predstavu o cene ešte pred hovorom slúži <a href="/kalkulacka" style="color:var(--forest); border-bottom:2px solid var(--lime)">kalkulačka</a>.</p>
      </div>
      <div class="reveal">
        <div class="cal-embed" id="my-cal-inline" style="width:100%;height:640px;overflow:auto"></div>
        <noscript>
          <p style="color:var(--ink-soft); margin-top:12px">Pre rezerváciu termínu zapni JavaScript, alebo napíš priamo na <a href="mailto:peter@ecomcapital.sk" style="color:var(--forest); border-bottom:2px solid var(--lime)">peter@ecomcapital.sk</a>.</p>
        </noscript>
      </div>
    </div>
  </section>
</Base>

<script is:inline define:vars={{ CAL_LINK }}>
  (function (C, A, L) {
    let p = function (a, ar) {
      a.q.push(ar);
    };
    let d = C.document;
    C.Cal =
      C.Cal ||
      function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement('script')).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () {
            p(api, arguments);
          };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === 'string') {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ['initNamespace', namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
  })(window, 'https://app.cal.com/embed/embed.js', 'init');

  Cal('init', { origin: 'https://app.cal.com' });
  Cal('inline', {
    elementOrSelector: '#my-cal-inline',
    calLink: CAL_LINK,
    layout: 'month_view',
  });
  Cal('ui', {
    cssVarsPerTheme: { light: { 'cal-brand': '#163300' } },
    hideEventTypeDetails: false,
    layout: 'month_view',
  });
</script>
