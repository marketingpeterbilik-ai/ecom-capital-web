---
import Base from '../layouts/Base.astro';
import Booking from '../components/Booking.astro';
---

<Base
  title="Kontakt — Ecom Capital"
  description="Nezáväzná konzultácia — krátky hovor o stave účtu a merania. Termín priamo v kalendári, alebo e-mailom na peter@ecomcapital.sk."
>
  <header class="hero--ink hero--page">
    <div class="hero-orb"></div>
    <div class="wrap hero-inner">
      <span class="eyebrow reveal">Kontakt</span>
      <h1 class="reveal" style="margin-top:18px">Nezáväzná konzultácia.</h1>
      <p class="hero-sub reveal">Krátky hovor o stave účtu a merania. Termín sa dá rezervovať priamo v kalendári nižšie.</p>
    </div>
  </header>

  <section class="sec" style="padding:56px 0">
    <div class="wrap contact-grid" style="margin-top:0">
      <div class="reveal">
        <div class="ctitem"><div class="l">E-mail</div><div class="v"><a href="mailto:peter@ecomcapital.sk">peter@ecomcapital.sk</a></div></div>
        <div class="ctitem"><div class="l">Lokalita</div><div class="v">Bratislava, Slovensko</div></div>
        <div class="ctitem"><div class="l">Záber</div><div class="v">PPC · Meranie · Dáta &amp; BigQuery</div></div>
        <div class="ctitem"><div class="l">Spolupráca</div><div class="v">Jednorazové projekty aj dlhodobá správa</div></div>
      </div>
      <div class="reveal">
        <p style="color:var(--ink-soft)">Pre orientačnú predstavu o cene ešte pred hovorom slúži <a href="/kalkulacka" style="color:var(--forest); border-bottom:2px solid var(--lime)">kalkulačka</a>.</p>
        <p style="color:var(--ink-soft); margin-top:14px">Odpoveď na e-mail príde do 48 hodín.</p>
      </div>
    </div>
  </section>

  <Booking eyebrow="Rezervácia termínu" title="Vyberte si čas, ktorý vám sedí." />
</Base>
