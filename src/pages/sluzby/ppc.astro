---
import Base from '../../layouts/Base.astro';
import Booking from '../../components/Booking.astro';
---

<Base
  title="Správa PPC kampaní — Ecom Capital"
  description="Dlhodobá správa Google a Meta Ads vrátane merania. Optimalizácia podľa zisku a marže, týždenné ladenie, mesačný report v slovenčine. Bez viazanosti."
>
  <header class="hero--ink hero--page">
    <div class="hero-orb"></div>
    <div class="wrap hero-inner">
      <span class="eyebrow reveal">Služby / PPC</span>
      <h1 class="reveal" style="margin-top:18px">Správa PPC kampaní.</h1>
      <p class="hero-sub reveal">Dlhodobá správa Google a Meta Ads vrátane merania. Kampane sa optimalizujú podľa zisku a marže a rozhodnutia sa dajú spätne overiť v dátach.</p>
    </div>
  </header>

  <section class="sec" style="padding-top:56px">
    <div class="wrap split split--wide">
      <div class="reveal">
        <span class="eyebrow">Čo zahŕňa</span>
        <h2 class="display" style="margin-top:16px; font-size:clamp(1.7rem,3.8vw,2.4rem)">Kampane aj meranie, na ktorom stoja.</h2>
        <p class="lead" style="margin-top:18px">Súčasťou správy je aj tracking — bez spoľahlivých dát sa kampane optimalizujú len odhadom. Nastavenie merania preto nie je samostatná položka, ale základ služby.</p>
      </div>
      <div class="reveal">
        <div class="feat"><div class="k">·</div><div><h3>Google Ads</h3><p>Search, Shopping a Performance Max. Štruktúra účtu, bidding stratégie a rozpočtový pacing.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Meta Ads</h3><p>Advantage+, retargeting a priebežné testovanie kreatív.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Produktové feedy</h3><p>Merchant Center, Mergado a custom labels — kvalitný feed je základ Shopping a Performance Max kampaní.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Meranie v cene správy</h3><p>GA4 a server-side tracking sú súčasťou služby.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Týždenná optimalizácia</h3><p>Negatíva, bidy, kreatívy a rozpočty sa ladia priebežne, nie raz za kvartál.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Mesačný report</h3><p>V slovenčine: čo sa stalo, prečo a čo ďalej.</p></div></div>
      </div>
    </div>
  </section>

  <section class="sec sec--tint">
    <div class="wrap">
      <p class="lead reveal">Spolupráca je bez viazanosti — dá sa ukončiť kedykoľvek, beží z mesiaca na mesiac. Účty, prístupy aj dáta zostávajú vaše. Priebeh prvých týždňov je popísaný na stránke <a href="/proces" style="color:var(--forest); border-bottom:2px solid var(--lime)">Proces</a>.</p>
    </div>
  </section>

  <Booking />
</Base>
