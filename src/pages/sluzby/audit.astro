---
import Base from '../../layouts/Base.astro';
import Booking from '../../components/Booking.astro';
---

<Base
  title="Audit & konzultácie — Ecom Capital"
  description="Nezávislé posúdenie reklamných účtov, merania a stratégie. Výstupom je akčný plán zoradený podľa dopadu na tržby."
>
  <header class="hero--ink hero--page">
    <div class="hero-orb"></div>
    <div class="wrap hero-inner">
      <span class="eyebrow reveal">Služby / Audit</span>
      <h1 class="reveal" style="margin-top:18px">Audit &amp; konzultácie.</h1>
      <p class="hero-sub reveal">Nezávislé posúdenie účtov, merania a stratégie. Výstupom je konkrétny zoznam toho, čo opraviť, čo škálovať a čo zastaviť — zoradený podľa dopadu na tržby.</p>
    </div>
  </header>

  <section class="sec" style="padding-top:56px">
    <div class="wrap split split--wide">
      <div class="reveal">
        <span class="eyebrow">Čo zahŕňa</span>
        <h2 class="display" style="margin-top:16px; font-size:clamp(1.7rem,3.8vw,2.4rem)">Účty, meranie aj stratégia.</h2>
        <p class="lead" style="margin-top:18px">Audit je zvyčajne prvý krok spolupráce — ukáže stav účtov a merania a dá sa podľa neho rozhodnúť, čo ďalej. Funguje aj samostatne, bez ďalšieho záväzku.</p>
      </div>
      <div class="reveal">
        <div class="feat"><div class="k">·</div><div><h3>Audit Google + Meta</h3><p>Štruktúra účtov, nastavenia kampaní, výkon a nevyužité možnosti.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Audit trackingu</h3><p>Kontrola merania a dátového toku — čo sa meria, čo chýba a čomu sa nedá veriť.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Akčný plán</h3><p>Konkrétne kroky zoradené podľa priority a odhadovaného dopadu.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Stratégia rastu</h3><p>Odporúčaný smer na 6–12 mesiacov — kanály, rozpočty, meranie.</p></div></div>
      </div>
    </div>
  </section>

  <Booking />
</Base>
