---
import Base from '../../layouts/Base.astro';
import Booking from '../../components/Booking.astro';
---

<Base
  title="Automatizácia — Ecom Capital"
  description="Automatické kontroly účtov, upozornenia na anomálie a automatizovaný reporting. Problémy sa odhalia skôr, než ovplyvnia rozpočet."
>
  <header class="hero--ink hero--page">
    <div class="hero-orb"></div>
    <div class="wrap hero-inner">
      <span class="eyebrow reveal">Služby / Automatizácia</span>
      <h1 class="reveal" style="margin-top:18px">Automatizácia.</h1>
      <p class="hero-sub reveal">Rutinné úlohy preberajú automatické kontroly a upozornenia. Problémy sa odhalia skôr, než ovplyvnia rozpočet.</p>
    </div>
  </header>

  <section class="sec" style="padding-top:56px">
    <div class="wrap split split--wide">
      <div class="reveal">
        <span class="eyebrow">Čo zahŕňa</span>
        <h2 class="display" style="margin-top:16px; font-size:clamp(1.7rem,3.8vw,2.4rem)">Menej manuálnej práce, viac kontroly.</h2>
        <p class="lead" style="margin-top:18px">Účty a feedy sa kontrolujú priebežne a automaticky. Ušetrený čas ide do práce, ktorá sa automatizovať nedá — stratégie a optimalizácie.</p>
      </div>
      <div class="reveal">
        <div class="feat"><div class="k">·</div><div><h3>Automatické kontroly účtov</h3><p>Nastavenia, rozpočty a výkon sa kontrolujú pravidelne, nie náhodne.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Upozornenia na anomálie</h3><p>Výkyvy vo výdajoch, konverziách alebo výpadky merania sa hlásia hneď.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Automatizovaný reporting</h3><p>Pravidelné reporty sa skladajú a doručujú automaticky, bez ručného kopírovania dát.</p></div></div>
        <div class="feat"><div class="k">·</div><div><h3>Riešenia na mieru</h3><p>Automatizácia rutín špecifických pre konkrétny e-shop alebo účet.</p></div></div>
      </div>
    </div>
  </section>

  <Booking />
</Base>
